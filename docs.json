{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "TinyCloud",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "font": {
    "headings": {
      "family": "Oswald",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "background": {
    "decoration": "grid"
  },
  "iconLibrary": "lucide",
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "indexing": "all"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart/web-sdk", "quickstart/node-sdk"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/spaces",
              "guides/kv-storage",
              "guides/tinycloud-vfs",
              "guides/write-hooks",
              "guides/data-vault",
              "guides/delegations",
              "guides/sharing"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/did-formats",
              "concepts/capabilities",
              "concepts/app-manifests"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["cli/overview", "cli/authentication"]
          },
          {
            "group": "Data",
            "pages": ["cli/storage", "cli/sql", "cli/spaces", "cli/secrets"]
          },
          {
            "group": "Collaboration",
            "pages": ["cli/delegations", "cli/profiles"]
          },
          {
            "group": "Operations",
            "pages": ["cli/diagnostics"]
          }
        ]
      },
      {
        "tab": "Hosting",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["hosting/overview", "hosting/configuration"]
          },
          {
            "group": "Deployment",
            "pages": ["hosting/docker", "hosting/databases", "hosting/storage"]
          },
          {
            "group": "Operations",
            "pages": ["hosting/monitoring"]
          }
        ]
      },
      {
        "tab": "OpenKey",
        "groups": [
          {
            "group": "Overview",
            "pages": ["openkey/index"]
          },
          {
            "group": "Getting Started",
            "pages": ["openkey/quickstart", "openkey/widget"]
          },
          {
            "group": "Integration",
            "pages": ["openkey/oauth", "openkey/tinycloud-integration"]
          }
        ]
      },
      {
        "tab": "Help",
        "groups": [
          {
            "group": "Support",
            "pages": ["troubleshooting"]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/tinycloud",
        "type": "discord"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.tinycloud.xyz"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tinycloudlabs",
      "github": "https://github.com/tinycloudlabs"
    }
  }
}
