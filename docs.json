{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "TinyCloud",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "font": {
    "headings": {
      "family": "Oswald",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "background": {
    "decoration": "grid"
  },
  "iconLibrary": "lucide",
  "favicon": "/favicon.svg",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "indexing": "all"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Start",
        "groups": [
          {
            "group": "Reader paths",
            "pages": [
              "index",
              "start/browser-app",
              "start/backend-service",
              "start/protocol",
              "start/operator"
            ]
          }
        ]
      },
      {
        "tab": "Build",
        "groups": [
          {
            "group": "Quickstarts",
            "pages": ["quickstart/web-sdk", "quickstart/node-sdk"]
          },
          {
            "group": "Authentication and data",
            "pages": [
              "guides/authentication",
              "guides/authentication/web",
              "guides/authentication/node",
              "openkey/tinycloud-integration",
              "guides/spaces",
              "guides/spaces/provisioning",
              "guides/kv-storage",
              "guides/kv/basic-operations",
              "guides/sql-schema-and-migrations"
            ]
          },
          {
            "group": "Collaboration and extensions",
            "pages": [
              "guides/delegations",
              "guides/sharing",
              "guides/data-vault",
              "guides/write-hooks",
              "guides/tinycloud-vfs",
              "guides/agent-readable-apps"
            ]
          }
        ]
      },
      {
        "tab": "Understand",
        "groups": [
          {
            "group": "Concepts",
            "pages": [
              "concepts/system-model",
              "concepts/security-and-trust",
              "concepts/did-formats",
              "concepts/capabilities",
              "concepts/app-manifests",
              "concepts/data-vault"
            ]
          },
          {
            "group": "SDK reference",
            "pages": [
              "reference/sdk/index",
              "reference/sdk/web",
              "reference/sdk/node"
            ]
          },
          {
            "group": "Protocol reference",
            "pages": [
              "reference/protocol/capabilities",
              "reference/protocol/app-manifests",
              "reference/protocol/delegations"
            ]
          },
          {
            "group": "Terminology",
            "pages": ["reference/glossary"]
          }
        ]
      },
      {
        "tab": "Operate",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/authentication",
              "cli/storage",
              "cli/sql",
              "cli/duckdb",
              "cli/spaces",
              "cli/secrets",
              "cli/delegations",
              "cli/auth-artifacts",
              "cli/profiles",
              "cli/status",
              "cli/manifest",
              "cli/diagnostics"
            ]
          },
          {
            "group": "Hosting",
            "pages": [
              "hosting/overview",
              "hosting/configuration",
              "hosting/docker",
              "hosting/databases",
              "hosting/storage",
              "hosting/monitoring"
            ]
          },
          {
            "group": "OpenKey",
            "pages": [
              "openkey/index",
              "openkey/quickstart",
              "openkey/widget",
              "openkey/oauth"
            ]
          },
          {
            "group": "Support",
            "pages": ["troubleshooting"]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://t.me/+-_2ufE0JgIcyMjYx"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Account",
      "href": "https://account.tinycloud.xyz/"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tinycloudlabs",
      "github": "https://github.com/tinycloudlabs"
    }
  }
}
